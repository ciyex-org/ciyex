{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Attach to Spring Boot (5005)",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005
    },
    {
      "type": "java",
      "name": "CiyexApplication",
      "request": "launch",
      "mainClass": "com.qiaben.ciyex.CiyexApplication",
      "projectName": "ciyex"
    },
    {
      "name": "Launch EHR UI (Next.js)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ciyex-ehr-ui",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      },
      "windows": {
        "runtimeExecutable": "pnpm.cmd"
      }
    },
    {
      "name": "Launch Portal UI (Next.js)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ciyex-portal-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development",
        "PORT": "3001"
      },
      "windows": {
        "runtimeExecutable": "npm.cmd"
      }
    },
    {
      "name": "Launch Admin UI (Next.js)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/ciyex-admin-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development",
        "PORT": "3002"
      },
      "windows": {
        "runtimeExecutable": "npm.cmd"
      }
    },
    {
      "name": "Launch Spring Boot Backend",
      "type": "java",
      "request": "launch",
      "mainClass": "com.qiaben.ciyex.CiyexApplication",
      "projectName": "ciyex",
      "cwd": "${workspaceFolder}",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      }
    },
    {
      "name": "Launch All Services (Node.js)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/start-all.js",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "windows": {
        "program": "${workspaceFolder}\\scripts\\start-all.js"
      }
    }
  ],
  "compounds": [
    {
      "name": "Run Spring Boot (Debug and Attach)",
      "configurations": ["Attach to Spring Boot (5005)"],
      "preLaunchTask": "Run Spring Boot (Debug JAR)"
    },
    {
      "name": "Launch Full Stack",
      "configurations": [
        "Launch Spring Boot Backend",
        "Launch EHR UI (Next.js)",
        "Launch Portal UI (Next.js)",
        "Launch Admin UI (Next.js)"
      ],
      "stopAll": true
    }
  ]
}
