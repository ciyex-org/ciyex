    {
      "label": "Build Spring Boot",
      "type": "shell",
      "command": "./gradlew",
      "args": ["build", "-x", "test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": [],
      "windows": {
        "command": "gradlew.bat"
      }
    },
    {
      "label": "Run Spring Boot",
      "type": "shell",
      "command": "./gradlew",
      "args": ["bootRun"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new"
      },
      "problemMatcher": [],
      "isBackground": true,
      "windows": {
        "command": "gradlew.bat"
      }
    },
    {
      "label": "Install All Dependencies",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Install EHR UI Dependencies",
        "Install Portal UI Dependencies",
        "Install Admin UI Dependencies"
      ],
      "group": "build"
    },
    {
      "label": "Build All UIs",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Build EHR UI",
        "Build Portal UI",
        "Build Admin UI"
      ],
      "group": "build"
    },
    {
      "label": "Start All Development",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Run Spring Boot",
        "Dev EHR UI",
        "Dev Portal UI",
        "Dev Admin UI"
      ],
      "group": "build"
    },
    {
      "label": "Start All Production",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build All UIs",
        "Build Spring Boot"
      ],
      "group": "build"
    },
    {
      "label": "Docker Build",
      "type": "shell",
      "command": "docker",
      "args": ["build", "-t", "ciyex-app", "."],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker Run",
      "type": "shell",
      "command": "docker",
      "args": ["run", "-p", "8080:8080", "-p", "3000:3000", "-p", "3001:3001", "-p", "3002:3002", "ciyex-app"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new"
      },
      "problemMatcher": [],
      "isBackground": true
    }
