{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check and Kill Port 8080",
      "type": "shell",
      "command": "lsof -ti:8080 | xargs kill -9 2>/dev/null || true",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Check and Kill Port 3000",
      "type": "shell",
      "command": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Check and Kill Port 3001",
      "type": "shell",
      "command": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Build Backend",
      "type": "shell",
      "command": "./gradlew",
      "args": [
        "compileJava",
        "build",
        "-x",
        "test",
        "--no-daemon"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Install EHR UI Dependencies",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ciyex-ehr-ui"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Install Portal UI Dependencies",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ciyex-portal-ui"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Build EHR UI",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ciyex-ehr-ui"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Build Portal UI",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ciyex-portal-ui"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Pre-launch Backend",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Check and Kill Port 8080",
        "Build Backend"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pre-launch EHR UI",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Check and Kill Port 3000",
        "Install EHR UI Dependencies"
      ],
      "problemMatcher": []
    },
    {
      "label": "Pre-launch Portal UI",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Check and Kill Port 3001",
        "Install Portal UI Dependencies"
      ],
      "problemMatcher": []
    }
  ]
}
