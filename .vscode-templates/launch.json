{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "name": "Ciyex Backend (Auto Build)",
      "request": "launch",
      "command": "SPRING_PROFILES_ACTIVE=local ./gradlew bootRun --no-daemon",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Pre-launch Backend"
    },
    {
      "type": "java",
      "name": "Ciyex Backend (Debug Mode)",
      "request": "launch",
      "mainClass": "com.qiaben.ciyex.CiyexApplication",
      "projectName": "ciyex",
      "cwd": "${workspaceFolder}",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      },
      "vmArgs": "-Dspring.profiles.active=local",
      "preLaunchTask": "Pre-launch Backend",
      "console": "integratedTerminal"
    },
    {
      "type": "node-terminal",
      "name": "EHR UI (Next.js)",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/ciyex-ehr-ui",
      "preLaunchTask": "Pre-launch EHR UI",
      "serverReadyAction": {
        "pattern": "- Local:.*http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "type": "node-terminal",
      "name": "Portal UI (Next.js)",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/ciyex-portal-ui",
      "preLaunchTask": "Pre-launch Portal UI",
      "serverReadyAction": {
        "pattern": "- Local:.*http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Backend + EHR UI)",
      "configurations": [
        "Ciyex Backend (Auto Build)",
        "EHR UI (Next.js)"
      ],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "Full Stack",
        "order": 1
      }
    },
    {
      "name": "Full Stack (Backend + Portal UI)",
      "configurations": [
        "Ciyex Backend (Auto Build)",
        "Portal UI (Next.js)"
      ],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "Full Stack",
        "order": 2
      }
    },
    {
      "name": "All Services (Backend + Both UIs)",
      "configurations": [
        "Ciyex Backend (Auto Build)",
        "EHR UI (Next.js)",
        "Portal UI (Next.js)"
      ],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "Full Stack",
        "order": 3
      }
    }
  ]
}
